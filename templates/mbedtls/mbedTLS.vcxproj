if not exist "$(OutDir)" mkdir "$(OutDir)"
lib.exe /nologo /OUT:"$(OutDir)mbedtls.lib" "$(MSBuildProjectDirectory)-$(Platform)\library\Debug\mbedtls.lib" "$(MSBuildProjectDirectory)-$(Platform)\library\Debug\mbedx509.lib" "$(MSBuildProjectDirectory)-$(Platform)\tf-psa-crypto\core\Debug\tfpsacrypto.lib" "$(MSBuildProjectDirectory)-$(Platform)\tf-psa-crypto\drivers\builtin\builtin.dir\Debug\builtin.lib" "$(MSBuildProjectDirectory)-$(Platform)\tf-psa-crypto\drivers\everest\everest.dir\Debug\everest.lib" "$(MSBuildProjectDirectory)-$(Platform)\tf-psa-crypto\drivers\p256-m\p256-m.dir\Debug\p256-m.lib"</Command>
      <Message>Combining mbedTLS component libs -&gt; $(OutDir)mbedtls.lib</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
