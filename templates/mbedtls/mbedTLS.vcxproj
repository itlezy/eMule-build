    <OutDir Condition="'$(Configuration)|$(Platform)'=='Release|ARM64'">$(MSBuildProjectDirectory)\$(Platform)\$(Configuration)\</OutDir>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <PreBuildEvent>
      <Command>IF NOT EXIST "$(MSBuildProjectDirectory)-$(Platform)\CMakeCache.txt" cmake -S "$(MSBuildProjectDirectory)\..\.." -B "$(MSBuildProjectDirectory)-$(Platform)" -G "Visual Studio 17 2022" -A $(Platform) -DENABLE_PROGRAMS=OFF -DENABLE_TESTING=OFF -DGEN_FILES=ON "-DCMAKE_POLICY_VERSION_MINIMUM=3.5" -DCMAKE_POLICY_DEFAULT_CMP0091=NEW "-DCMAKE_MSVC_RUNTIME_LIBRARY=MultiThreaded$&lt;$&lt;CONFIG:Debug&gt;:Debug&gt;" "-DPERL_EXECUTABLE=%ProgramFiles%/Git/usr/bin/perl.exe"</Command>
