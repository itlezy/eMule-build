IF %ERRORLEVEL% NEQ 0 EXIT /B %ERRORLEVEL%
IF NOT EXIST "$(MSBuildProjectDirectory)\$(Platform)\Release" MD "$(MSBuildProjectDirectory)\$(Platform)\Release"
COPY /Y "$(MSBuildProjectDirectory)\..\..\..\cmake-build-$(Platform)\Release\zs.lib" "$(MSBuildProjectDirectory)\$(Platform)\Release\zlib.lib"</Command>
