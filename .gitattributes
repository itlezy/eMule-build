# Default: auto-detect text files and normalise to LF in the repo
* text=auto

# Patch files must be LF — git apply requires it
*.patch text eol=lf
*.md    text eol=lf
.editorconfig text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.gitmodules    text eol=lf
*.psd1  text eol=crlf

# Windows project and script files use CRLF on checkout
*.vcxproj text eol=crlf
*.props   text eol=crlf
*.sln     text eol=crlf
*.cmd     text eol=crlf
*.bat     text eol=crlf
*.ps1     text eol=crlf
