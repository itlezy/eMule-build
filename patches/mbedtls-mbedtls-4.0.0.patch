+<?xml version="1.0" encoding="utf-8"?>
+<!--
+  Wrapper project: builds all MbedTLS 4.0 component libs then combines them
+  into a single mbedtls.lib at $(Platform)\$(Configuration)\mbedtls.lib.
+
+  emule.vcxproj expects:  ..\eMule-mbedtls\visualc\VS2017\$(Platform)\$(Configuration)\mbedtls.lib
+  This project produces:  visualc\VS2017\$(Platform)\$(Configuration)\mbedtls.lib
+
+  Prerequisites: run workspace.ps1 setup first (setup.ps1 is only a compatibility wrapper).
+-->
+<Project DefaultTargets="Build" ToolsVersion="17.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
+  <ItemGroup Label="ProjectConfigurations">
+    <ProjectConfiguration Include="Debug|x64">
+      <Configuration>Debug</Configuration>
+      <Platform>x64</Platform>
+    </ProjectConfiguration>
+    <ProjectConfiguration Include="Release|x64">
+      <Configuration>Release</Configuration>
+      <Platform>x64</Platform>
+    </ProjectConfiguration>
+  </ItemGroup>
+  <PropertyGroup Label="Globals">
+    <ProjectGuid>{F1A2B3C4-D5E6-7890-ABCD-EF1234567890}</ProjectGuid>
+    <Keyword>Win32Proj</Keyword>
+    <Platform>x64</Platform>
+    <ProjectName>mbedTLS</ProjectName>
+    <VCProjectUpgraderObjectName>NoUpgrade</VCProjectUpgraderObjectName>
+  </PropertyGroup>
+  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
+  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
+    <ConfigurationType>Utility</ConfigurationType>
+    <PlatformToolset>v143</PlatformToolset>
+  </PropertyGroup>
+  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
+    <ConfigurationType>Utility</ConfigurationType>
+    <PlatformToolset>v143</PlatformToolset>
+  </PropertyGroup>
+  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
+  <ImportGroup Label="ExtensionSettings">
+  </ImportGroup>
+  <ImportGroup Label="PropertySheets">
+    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
+  </ImportGroup>
+  <PropertyGroup Label="UserMacros" />
+  <PropertyGroup>
+    <_ProjectFileVersion>10.0.20506.1</_ProjectFileVersion>
+    <OutDir Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">$(MSBuildProjectDirectory)\$(Platform)\$(Configuration)\</OutDir>
+    <IntDir Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">$(Platform)\$(Configuration)\tmp\</IntDir>
+    <OutDir Condition="'$(Configuration)|$(Platform)'=='Release|x64'">$(MSBuildProjectDirectory)\$(Platform)\$(Configuration)\</OutDir>
+    <IntDir Condition="'$(Configuration)|$(Platform)'=='Release|x64'">$(Platform)\$(Configuration)\tmp\</IntDir>
+  </PropertyGroup>
+  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
+    <PostBuildEvent>
+      <Command>if not exist "$(OutDir)" mkdir "$(OutDir)"
+lib.exe /nologo /OUT:"$(OutDir)mbedtls.lib" "$(MSBuildThisFileDirectory)library\Debug\mbedtls.lib" "$(MSBuildThisFileDirectory)library\Debug\mbedx509.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\core\Debug\tfpsacrypto.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\builtin\builtin.dir\Debug\builtin.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\everest\everest.dir\Debug\everest.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\p256-m\p256m.dir\Debug\p256m.lib"</Command>
+      <Message>Combining mbedTLS component libs -&gt; $(OutDir)mbedtls.lib</Message>
+    </PostBuildEvent>
+  </ItemDefinitionGroup>
+  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
+    <PostBuildEvent>
+      <Command>if not exist "$(OutDir)" mkdir "$(OutDir)"
+lib.exe /nologo /OUT:"$(OutDir)mbedtls.lib" "$(MSBuildThisFileDirectory)library\Release\mbedtls.lib" "$(MSBuildThisFileDirectory)library\Release\mbedx509.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\core\Release\tfpsacrypto.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\builtin\builtin.dir\Release\builtin.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\everest\everest.dir\Release\everest.lib" "$(MSBuildThisFileDirectory)tf-psa-crypto\drivers\p256-m\p256m.dir\Release\p256m.lib"</Command>
+      <Message>Combining mbedTLS component libs -&gt; $(OutDir)mbedtls.lib</Message>
+    </PostBuildEvent>
+  </ItemDefinitionGroup>
+  <ItemGroup>
+    <!-- mbedtls (TLS layer) -->
+    <ProjectReference Include="library\mbedtls.vcxproj">
+      <Project>{A32A45E2-6CCE-31A6-A062-B0FDB3CFA2B2}</Project>
+    </ProjectReference>
+    <!-- mbedx509 (X.509 / certificate layer) -->
+    <ProjectReference Include="library\mbedx509.vcxproj">
+      <Project>{D3C64AC5-8247-35B3-9108-0D37876489D6}</Project>
+    </ProjectReference>
+    <!-- tfpsacrypto (PSA crypto core) -->
+    <ProjectReference Include="tf-psa-crypto\core\tfpsacrypto.vcxproj">
+      <Project>{AEBF1838-3AF1-35E5-8CCD-A1630560B83D}</Project>
+    </ProjectReference>
+    <!-- builtin (software crypto driver) -->
+    <ProjectReference Include="tf-psa-crypto\drivers\builtin\builtin.vcxproj">
+      <Project>{3832784E-3078-3367-A299-9E01C69B76BA}</Project>
+    </ProjectReference>
+    <!-- everest (Curve25519/X25519 driver) -->
+    <ProjectReference Include="tf-psa-crypto\drivers\everest\everest.vcxproj">
+      <Project>{CB89BD2F-FBB6-3C94-90CE-A3924A232E69}</Project>
+    </ProjectReference>
+    <!-- p256-m (P-256 driver) -->
+    <ProjectReference Include="tf-psa-crypto\drivers\p256-m\p256m.vcxproj">
+      <Project>{38961768-A35A-375F-B7AD-60EF8BEEF095}</Project>
+    </ProjectReference>
+  </ItemGroup>
+  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
+  <ImportGroup Label="ExtensionTargets">
+  </ImportGroup>
+</Project>
