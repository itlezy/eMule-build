-// Limit the <arm_acle.h> include.
-#if !defined(CRYPTOPP_ARM_ACLE_HEADER)
-# if defined(__aarch32__) || defined(__aarch64__) || (__ARM_ARCH >= 8) || defined(__ARM_ACLE)
-#  define CRYPTOPP_ARM_ACLE_HEADER 1
-# endif
